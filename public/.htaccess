<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Handle API requests via PHP
  RewriteRule ^api/market-data/?$ php/market-data.php [L]

  # 2. Remove trailing slashes from URLs
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # 3. Support Clean URLs (Map /path to /path.html)
  # Even if a directory exists, prioritize the .html file for cleaner reloads
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*)$ $1.html [L]

</IfModule>

# 3. Security Headers
<IfModule mod_headers.c>
  # Prevent Clickjacking
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # Referrer Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Disable unused browser features
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  
  # Force HTTPS (HSTS) - Only if SSL is active
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# 4. Prevent directory listing
Options -Indexes
